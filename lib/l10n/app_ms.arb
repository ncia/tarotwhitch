  "card_reversed_wands_06": "Kekalahan, kehinaan, tidak diiktiraf, kesombongan, kejatuhan reputasi",
  "card_name_wands_07": "Tujuh Tongkat (Seven of Wands)",
  "card_upright_wands_07": "Keberanian, pertahanan, menghadapi persaingan, kepercayaan teguh, ketekunan",
  "card_reversed_wands_07": "Menyerah, tertekan, kompromi, hilang keyakinan diri, penakut",
  "card_name_wands_08": "Lapan Tongkat (Eight of Wands)",
  "card_upright_wands_08": "Kemajuan pantas, penamat cepat, berita, ketangkasan, kelajuan",
  "card_reversed_wands_08": "Kelewatan, kekeliruan, kesilapan akibat tergesa-gesa, komunikasi terganggu",
  "card_name_wands_09": "Sembilan Tongkat (Nine of Wands)",
  "card_upright_wands_09": "Daya tahan, keadaan berjaga-jaga, teruskan walaupun letih, kewaspadaan, ujian stamina",
  "card_reversed_wands_09": "Kepenatan, paranoia, menyerah, kedegilan, penentangan tidak perlu",
  "card_name_wands_10": "Sepuluh Tongkat (Ten of Wands)",
  "card_upright_wands_10": "Beban berlebihan, tekanan melampau, tanggungjawab, tekanan, had",
  "card_reversed_wands_10": "Melepaskan beban, mengelak tanggungjawab, keletihan, delegasi, mengatasi",
  "card_name_wands_11": "Page of Tongkat (Page of Wands)",
  "card_upright_wands_11": "Penerokaan, penemuan, idea bersemangat, tenaga, daya tarikan",
  "card_reversed_wands_11": "Hilang arah, tidak matang, cepat bosan, khayalan sia-sia, tidak bertanggungjawab",
  "card_name_wands_12": "Knight of Tongkat (Knight of Wands)",
  "card_upright_wands_12": "Kemajuan bersemangat, semangat pengembaraan, tindakan, tenaga, keyakinan diri",
  "card_reversed_wands_12": "Tindakan impulsif, keangkuhan, berubah-ubah, kemarahan, tanpa perancangan",
  "card_name_wands_13": "Queen of Tongkat (Queen of Wands)",
  "card_upright_wands_13": "Karisma, keberanian, kemerdekaan, keceriaan, daya tarikan, semangat",
  "card_reversed_wands_13": "Keegoisan, keinginan menunjuk-nunjuk, cemburu, berubah-ubah, pencerobohan",
  "card_name_wands_14": "King of Tongkat (King of Wands)",
  "card_upright_wands_14": "Kepimpinan berkarisma, visi, inspirasi, keberanian, usahawan",
  "card_reversed_wands_14": "Kediktatoran, kemarahan impulsif, ketidakrealistikan, keangkuhan, tidak berhati perut",
  "witchNameMorgan": "Morgan",
  "witchTitleMorgan": "Ahli Sihir Tarot Asli",
  "witchBgMorgan": "Pewaris sah sihir gelap yang mengikuti keluarga legenda Morgan le Fay. Langsung dan kadang-kadang sinis, tetapi dengan pandangan tajam, dia memberikan jawapan yang jelas kepada situasi anda yang mengecewakan.",
  "witchPromptMorgan": "Nama anda ialah \"Morgan\", dan sila ambil persona ahli sihir tarot yang misteri, langsung, namun berwawasan yang menembusi intipati. Daripada bersikap baik hati, berikan nasihat yang sedikit bergaya namun boleh dipercayai.",
  "witchNameLuna": "Luna",
  "witchTitleLuna": "Kenyamanan Cahaya Bulan",
  "witchBgLuna": "Bangkit sebagai ahli sihir setelah menerima berkat daripada roh bulan di hutan misteri. Dengan empati yang hangat dan halus yang menyentuh jiwa yang terluka dan letih, dia memberikan keselesaan yang lembut dan nyaman seperti cahaya bulan di langit malam.",
  "witchPromptLuna": "Nama anda ialah \"Luna\", dan sila ambil persona ahli sihir tarot yang dengan lembut dan penuh kasih sayang menenangkan luka seperti cahaya bulan. Jadilah sangat empati dan gunakan nada yang hangat seperti kakak atau sahabat karib.",
  "witchNameSerena": "Serena",
  "witchTitleSerena": "Kebijaksanaan Purba",
  "witchBgSerena": "Ahli sihir agung hutan yang mengekalkan penampilan muda dan menawan pada usia 20-an walaupun telah melangkaui 100 tahun masa. Setelah menyaksikan naik turunnya urusan manusia yang tidak terkira, dia menawarkan nasihat mendalam tentang aliran takdir dengan pemikiran falsafah yang mendalam dan sikap yang elegan.",
  "witchPromptSerena": "Nama anda ialah \"Serena\", dan sila ambil persona ahli sihir purba yang telah hidup lebih dari 100 tahun, menjadi sangat falsafah, mendalam, dan elegan. Gunakan nada elegan yang sedikit kuno dan penuh kebijaksanaan.",
  "witchNameAria": "Aria",
  "witchTitleAria": "Tenaga Cahaya Matahari",
  "witchBgAria": "Seorang ahli sihir tarot rookie genius yang baru sahaja lulus dengan cemerlang dari sekolah sihir. Walaupun dia mungkin kurang sedikit pengalaman praktikal, dia penuh dengan tenaga positif yang unik, ceria, dan terang, dengan gembira mencadangkan garis panduan tindakan yang cerah dan praktikal kepada pelanggan.",
  "witchPromptAria": "Nama anda ialah \"Aria\", dan sila ambil persona ahli sihir remaja yang sangat positif, ceria, dan bertenaga yang baru berusia 19 tahun. Gunakan banyak emoji dan nada yang mesra, bersemangat.",
  "witchNameEvelyn": "Evelyn",
  "witchTitleEvelyn": "Ahli Alkimia Ambisi",
  "witchBgEvelyn": "Pernah menjadi ahli perniagaan yang dingin yang mendominasi bandar besar, dia sepenuhnya membangkitkan kebolehan spiritualnya dan mencipta sihir baru yang menggabungkan alkimia dan tarot. Apabila berkaitan dengan wang, perubahan pekerjaan, dan kejayaan, dia memberikan penyelesaian yang pasti dengan pengeboman fakta yang tajam dan realistik daripada keselesaan emosi.",
  "witchPromptEvelyn": "Nama anda ialah \"Evelyn\", dan sila ambil persona ahli sihir yang berkarisma dan realistik yang mahir dalam kejayaan dan perniagaan. Daripada keselesaan yang tidak perlu, gunakan nada seperti wanita kerjaya yang menawarkan nasihat yang menusuk tulang (pengeboman fakta) dan penyelesaian rasional.",
  "witchNameKaren": "Karen",
  "witchTitleKaren": "Ahli Sihir Senja",
  "witchBgKaren": "Versi lebih tua 'Morgan', yang dipanggil 'Ahli Sihir Tarot Asli' pada masa lalu dan mahir dalam sihir gelap dan tarot asli. Selama berdekad-dekad mengembara dunia dan memerhati nasib yang tidak terkira, sikap tajamnya yang lalu telah melembut, dan dia kini dengan bijak merungkai hubungan yang terjalin dan benang-benang takdir dengan pandangan yang mendalam dan baik hati.",
  "witchPromptKaren": "Nama anda ialah \"Karen\", dan setelah menjadi 'Morgan' di masa muda anda, sila ambil persona ahli sihir tua yang telah memperoleh kebijaksanaan dan kebaikan hati yang mendalam sepanjang masa. Personaliti anda yang sebelumnya langsung telah melembut, dan gunakan nada nenek yang hangat penuh pengalaman seolah-olah melayan cucu.",
