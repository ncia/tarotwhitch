  "card_name_major_00": "0. Հիմարը (The Fool)",
  "card_upright_major_00": "Նոր սկիզբ, արկածներ, անսահման հնարավորություններ, ազատություն, մաքրություն",
  "card_reversed_major_00": "Անխոհեմություն, հիմարություն, անզգուշություն, չափազանց մեծ ռիսկեր, անիրատեսություն",
  "card_name_major_01": "I. Հրաշագործը (The Magician)",
  "card_upright_major_01": "Ստեղծագործություն, կամք, կարողություն, նոր սկզբի ուժ, վճռականություն",
  "card_reversed_major_01": "Մանիպուլյացիա, տաղանդի վատնում, խաբեություն, ինքնավստահության պակաս, թաքնված մտադրություններ",
  "card_name_major_02": "II. Բարձրագույն Քրմուհին (The High Priestess)",
  "card_upright_major_02": "Ինտուիցիա, անգիտակցական, առեղծված, իմաստություն, ներքին ձայն",
  "card_reversed_major_02": "Ինտուիցիայի անտեսում, մակերեսային գիտելիքներ, թաքնված թշնամիներ, գաղտնիքների բացահայտում",
  "card_name_major_03": "III. Կայսրուհին (The Empress)",
  "card_upright_major_03": "Առատություն, մայրական սեր, գեղեցկություն, բնության պտուղներ, ստեղծագործություն",
  "card_reversed_major_03": "Չափից դուրս խնամք, կախվածություն, ստեղծագործական պակաս, ծուլություն, լճացում",
  "card_name_major_04": "IV. Կայսրը (The Emperor)",
  "card_upright_major_04": "Իշխանություն, կառուցվածք, կայունություն, հայրական սեր, վերահսկողություն, պատասխանատվություն",
  "card_reversed_major_04": "Բռնապետություն, տիրապետելու ցանկություն, ճկունության պակաս, անկարողություն, ճնշում",
  "card_name_major_05": "V. Քրմապետը (The Hierophant)",
  "card_upright_major_05": "Ավանդույթ, հավատ, կրթություն, հոգևոր առաջնորդություն, պահպանողականություն",
  "card_reversed_major_05": "Ապստամբություն, ավանդույթների խախտում, դոգմատիկ վերաբերմունք, հնացած գաղափարներ, վատ խորհուրդ",
  "card_name_major_06": "VI. Սիրահարները (The Lovers)",
  "card_upright_major_06": "Սեր, ներդաշնակություն, հարաբերություններ, կարևոր ընտրություն, վստահություն",
  "card_reversed_major_06": "Անհամաձայնություն, սխալ ընտրություն, վստահության կորուստ, գայթակղություն, անհավասարակշռություն",
  "card_name_major_07": "VII. Մարտակառքը (The Chariot)",
  "card_upright_major_07": "Կամք, հաղթանակ, վճռականություն, ուղղություն, հաջողության ձգտում",
  "card_reversed_major_07": "Վերահսկողության կորուստ, ուղղության կորուստ, անզորություն, ագրեսիա, խոչընդոտներ",
  "card_name_major_08": "VIII. Ուժը (Strength)",
  "card_upright_major_08": "Քաջություն, համբերություն, ներքին ուժ, նուրբ վերահսկողություն, կարեկցանք",
  "card_reversed_major_08": "Վախ, թուլություն, ինքնատիրապետման կորուստ, իմպուլսիվություն, ամբարտավանություն",
  "card_name_major_09": "IX. Ճգնավորը (The Hermit)",
  "card_upright_major_09": "Ներքին որոնում, իմաստություն, մենակություն, լուսավորություն, հոգևոր խորհրդատու",
  "card_reversed_major_09": "Մեկուսացում, միայնություն, իրականությունից փախուստ, հիմար համառություն, ճգնավորություն",
  "card_name_major_10": "X. Բախտի Անիվը (Wheel of Fortune)",
  "card_upright_major_10": "Շրջադարձային կետ, ճակատագիր, հաջողություն, անընդհատ փոփոխություններ, հնարավորություն",
  "card_reversed_major_10": "Անհաջողություն, դիմադրություն, անվերահսկելի փոփոխություններ, դժբախտության կրկնություն",
  "card_name_major_11": "XI. Արդարություն (Justice)",
  "card_upright_major_11": "Արդարություն, ճշմարտություն, հատուցում, հավասարակշռություն, ռացիոնալ որոշում",
  "card_reversed_major_11": "Անարդարություն, կանխակալություն, անազնվություն, անխուսափելի պատիժ, անհավասարակշռություն",
  "card_name_major_12": "XII. Կախված Մարդը (The Hanged Man)",
  "card_upright_major_12": "Զոհաբերություն, նոր հեռանկար, սպասում, խորաթափանցություն, ժամանակավոր դադար",
  "card_reversed_major_12": "Անիմաստ զոհաբերություն, ուշացում, զարգացման մերժում, եսասիրություն",
  "card_name_major_13": "XIII. Մահ (Death)",
  "card_upright_major_13": "Ավարտ և նոր սկիզբ, փոփոխություն, անցումային շրջան, անցյալի մաքրում",
  "card_reversed_major_13": "Դիմադրություն փոփոխություններին, լճացում, հնին կպչելը, վախ",
  "card_name_major_14": "XIV. Ժուժկալություն (Temperance)",
  "card_upright_major_14": "Ներդաշնակություն, հավասարակշռություն, չափավորություն, բուժում, նպատակասլացություն",
  "card_reversed_major_14": "Անհավասարակշռություն, անզսպություն, ծայրահեղ գործողություններ, աններդաշնակություն, հակամարտություն",
  "card_name_major_15": "XV. Սատանա (The Devil)",
  "card_upright_major_15": "Կապվածություն, մատերիալիզմ, կապանքներ, գայթակղություն, կործանարար ցանկություն",
  "card_reversed_major_15": "Ազատագրում, կապանքներից ազատվելը, անկախություն, լուսավորություն, ազատություն",
  "card_name_major_16": "XVI. Աշտարակը (The Tower)",
  "card_upright_major_16": "Հանկարծակի փոփոխություն, կործանում, ազատագրում, հայտնություն, փլուզում",
  "card_reversed_major_16": "Աղետից խուսափելը, անխուսափելի փոփոխության հետաձգում, զգուշացումների անտեսում",
  "card_name_major_17": "XVII. Աստղը (The Star)",
  "card_upright_major_17": "Հույս, ոգեշնչում, հանգստություն, բուժում և դրականություն, հոգևոր առաջնորդություն",
  "card_reversed_major_17": "Հուսահատություն, հիասթափություն, ոգեշնչման պակաս, հոռետեսություն, շփոթություն",
  "card_name_major_18": "XVIII. Լուսինը (The Moon)",
  "card_upright_major_18": "Անհանգստություն, պատրանքներ, ինտուիցիա, թաքնված ճշմարտություն, խաբեություն",
  "card_reversed_major_18": "Վախի հաղթահարում, գաղտնիքների բացահայտում, անհանգստության վերացում, ճշմարտության բացահայտում",
  "card_name_major_19": "XIX. Արևը (The Sun)",
  "card_upright_major_19": "Հաջողություն, դրականություն, կենսունակություն, երջանկություն և ձեռքբերում, ուրախություն",
  "card_reversed_major_19": "Հետաձգված հաջողություն, չափազանցություն, կենսունակության անկում, տխրության հակառակ կողմը",
  "card_name_major_20": "XX. Դատաստան (Judgement)",
  "card_upright_major_20": "Հարություն, վճռականություն, ներում, նոր կոչում, ներքին զարթոնք",
  "card_reversed_major_20": "Զղջում, ինքնակասկած, փոփոխության վախ, չբացահայտված ցանկություն, պատիժ",
  "card_name_major_21": "XXI. Աշխարհը (The World)",
  "card_upright_major_21": "Ավարտ, ձեռքբերում, ինտեգրում, նոր հարթություն, հաջող ավարտ",
  "card_reversed_major_21": "Անավարտություն, հետաձգում, լճացում, հաջողության վախ, ուշացում",
  "card_name_cups_01": "Գավաթների մեկ (Ace of Cups)",
  "card_upright_cups_01": "Նոր զգացմունքներ, սիրո սկիզբ, ինտուիցիա, հոգևոր լիություն",
  "card_reversed_cups_01": "Զգացմունքների արգելափակում, անսիրություն, դատարկություն, տխրություն",
  "card_name_cups_02": "Գավաթների երկու (Two of Cups)",
  "card_upright_cups_02": "Հարաբերությունների ներդաշնակություն, միություն, սեր, փոխադարձ հարգանք, համագործակցություն",
  "card_reversed_cups_02": "Հարաբերությունների անհամաձայնություն, բաժանում, թյուրիմացություն, անհավասարակշռություն, անպատասխան սեր",
  "card_name_cups_03": "Գավաթների երեք (Three of Cups)",
  "card_upright_cups_03": "Տոնակատարություն, բարեկամություն, համայնք, ուրախություն, ստեղծագործական պտուղներ",
  "card_reversed_cups_03": "Չափից դուրս խմիչք, մեկուսացում, խմբակցություններ, եռանկյունի հարաբերություններ, տոնակատարության չեղարկում",
  "card_name_cups_04": "Գավաթների չորս (Four of Cups)",
  "card_upright_cups_04": "Անտարբերություն, ձանձրույթ, մեդիտացիա, բաց թողնված հնարավորություն, ինքնահայեցողություն",
  "card_reversed_cups_04": "Նոր գիտակցություն, հնարավորությունից օգտվել, կենսունակության վերականգնում, զարթոնք",
  "card_name_cups_05": "Գավաթների հինգ (Five of Cups)",
  "card_upright_cups_05": "Կորուստ, տխրություն, անցյալի համար զղջում, հոռետեսություն",
  "card_reversed_cups_05": "Կորստի հաղթահարում, ընդունում, բուժում, նոր հույսի գտնելը",
  "card_name_cups_06": "Գավաթների վեց (Six of Cups)",
  "card_upright_cups_06": "Անցյալի կարոտ, մանկություն, մաքրություն, հին ընկերներ, հիշողություններ",
  "card_reversed_cups_06": "Անցյալին կպչելը, ապագայի անտեսում, անկախություն, աճ",
  "card_name_cups_07": "Գավաթների յոթ (Seven of Cups)",
  "card_upright_cups_07": "Պատրանքներ, երազանքներ, ընտրության շփոթություն, իրականությունից փախուստ, ցերեկային երազանքներ",
  "card_reversed_cups_07": "Իրականությանը դիմակայել, հստակ նպատակներ, պատրանքներից արթնանալ, վճռականություն",
  "card_name_cups_08": "Գավաթների ութ (Eight of Cups)",
  "card_upright_cups_08": "Հիասթափություն, հեռանալը, հանձնվելը ավելի խորը իմաստ փնտրելու համար, հրաժարում",
  "card_reversed_cups_08": "Չկարողանալ հեռանալ, անցյալին կպչելը, հարաբերությունների վերականգնում, վախ",
  "card_name_cups_09": "Գավաթների ինը (Nine of Cups)",
  "card_upright_cups_09": "Ցանկությունների իրականացում, բավարարվածություն, զգայական հաճույք, հպարտություն, երջանկություն",
  "card_reversed_cups_09": "Անբավարարվածություն, ամբարտավանություն, մակերեսային հաջողություն, ագահություն, ժլատություն",
  "card_name_cups_10": "Գավաթների տասը (Ten of Cups)",
  "card_upright_cups_10": "Ընտանեկան երջանկություն, խաղաղություն, հուզական լիություն, ներդաշնակ հարաբերություններ",
  "card_reversed_cups_10": "Ընտանեկան կոնֆլիկտներ, կոտրված ընտանիք, անհամաձայնություն, խաղաղության կորուստ",
  "card_name_cups_11": "Գավաթների սպասավորը (Page of Cups)",
  "card_upright_cups_11": "Նոր ոգեշնչում, ստեղծագործականություն, հուզական հաղորդագրություն, ինտուիտիվ կարողություն",
  "card_reversed_cups_11": "Հուզական անհասունություն, ստեղծագործական արգելափակում, վատ լուրեր, զգայունություն",
  "card_name_cups_12": "Գավաթների ասպետը (Knight of Cups)",
  "card_upright_cups_12": "Ռոմանտիկա, հմայք, հուզական մոտեցում, երևակայություն, ասպետություն",
  "card_reversed_cups_12": "Անիրատեսություն, քմահաճություն, նախանձ, անվստահելիություն, խաբեություն",
  "card_name_cups_13": "Գավաթների թագուհին (Queen of Cups)",
  "card_upright_cups_13": "Կարեկցանք, քնքշություն, հոգևոր ինտուիցիա, հուզական կայունություն, հոգատարություն",
  "card_reversed_cups_13": "Զգացմունքային ավելցուկ, անկայունություն, կախվածության հակում, զոհի դեր խաղալ",
  "card_name_cups_14": "Գավաթների արքան (King of Cups)",
  "card_upright_cups_14": "Հուզական վերահսկողություն, հավասարակշռություն, դիվանագիտություն, հանդուրժողականություն, իմաստուն խորհուրդ",
  "card_reversed_cups_14": "Հուզական մանիպուլյացիա, սառնություն, անկայունություն, քմահաճություն, անողոքություն",
  "card_name_pentacles_01": "Դրամների մեկ (Ace of Pentacles)",
  "card_upright_pentacles_01": "Նոր հնարավորություններ, ֆինանսական սկիզբ, առատություն, իրատեսական ձեռքբերումներ",
  "card_reversed_pentacles_01": "Կորցրած հնարավորություններ, ֆինանսական կորուստներ, ուշացում, վատ ներդրումներ",
  "card_name_pentacles_02": "Դրամների երկու (Two of Pentacles)",
  "card_upright_pentacles_02": "Հավասարակշռություն, հարմարվողականություն, ժամանակի/ֆինանսների կառավարում, ճկունություն",
  "card_reversed_pentacles_02": "Անհավասարակշռություն, ծանրաբեռնվածություն, ֆինանսական դժվարություններ, սթրես",
  "card_name_pentacles_03": "Դրամների երեք (Three of Pentacles)",
  "card_upright_pentacles_03": "Թիմային աշխատանք, համագործակցություն, հմտություններ, ճանաչված ջանքեր, կառուցում",
  "card_reversed_pentacles_03": "Համագործակցության պակաս, հմտությունների պակաս, չճանաչվելը, կարծիքների տարաձայնություններ",
  "card_name_pentacles_04": "Դրամների չորս (Four of Pentacles)",
  "card_upright_pentacles_04": "Կայունություն, սեփականատիրական զգացում, պահպանողականություն, ժլատություն, կուտակում",
  "card_reversed_pentacles_04": "Ագահության հետևանքներ, կորուստ, ֆինանսական անփութություն, կապվածությունից ազատվել",
  "card_name_pentacles_05": "Դրամների հինգ (Five of Pentacles)",
  "card_upright_pentacles_05": "Աղքատություն, ֆինանսական/հուզական պակաս, մեկուսացում, դժվարություններ",
  "card_reversed_pentacles_05": "Ֆինանսական վերականգնում, օգնության ձեռք, դժվարությունների հաղթահարում, դրական փոփոխություններ",
  "card_name_pentacles_06": "Դրամների վեց (Six of Pentacles)",
  "card_upright_pentacles_06": "Բարեգործություն, կիսվել, հովանավորություն, արդարություն, տալը և ստանալը",
  "card_reversed_pentacles_06": "Եսասիրություն, պարտքեր, անհավասարություն, ցուցադրական առատաձեռնություն, շահագործում",
  "card_name_pentacles_07": "Դրամների յոթ (Seven of Pentacles)",
  "card_upright_pentacles_07": "Համբերություն, երկարաժամկետ տեսլական, ջանքերի վարձատրության սպասում, գնահատում",
  "card_reversed_pentacles_07": "Անհամբերություն, անարդյունք ջանքեր, ուշացում, հիասթափություն, ներդրումային ձախողում",
  "card_name_pentacles_08": "Դրամների ութ (Eight of Pentacles)",
  "card_upright_pentacles_08": "Արհեստավորություն, նվիրվածություն, մանրամասների նկատմամբ ուշադրություն, հմտություն",
  "card_reversed_pentacles_08": "Ձանձրույթ, պերֆեկցիոնիզմի թակարդ, ծուլություն, կրքի կորուստ",
  "card_name_pentacles_09": "Դրամների ինը (Nine of Pentacles)",
  "card_upright_pentacles_09": "Ձեռքբերում, անկախություն, հարմարավետություն, ֆինանսական բարեկեցություն, ինքնավարձատրություն",
  "card_reversed_pentacles_09": "Ավելորդ ծախսեր, միայն արտաքին փայլ, կախվածություն, ֆինանսական անկայունություն",
  "card_name_pentacles_10": "Դրամների տասը (Ten of Pentacles)",
  "card_upright_pentacles_10": "Ընտանեկան բիզնես, հարստության կուտակում, ժառանգություն, կայուն կյանք, ավանդույթ",
  "card_reversed_pentacles_10": "Գույքի կորուստ, ընտանեկան վեճեր, ավանդույթների դեմ ընդվզում, անկայունություն",
  "card_name_pentacles_11": "Դրամների սպասավորը (Page of Pentacles)",
  "card_upright_pentacles_11": "Իրատեսական նպատակներ, նոր ուսումնասիրություններ, հնարավորություններ, գործնականություն, պլանավորում",
  "card_reversed_pentacles_11": "Պլանների ուշացում, գործնականության պակաս, ծուլություն, հետաձգելու սովորություն",
  "card_name_pentacles_12": "Դրամների ասպետը (Knight of Pentacles)",
  "card_upright_pentacles_12": "Ազնվություն, պատասխանատվություն, համառություն, աստիճանական զարգացում, հուսալիություն",
  "card_reversed_pentacles_12": "Համառություն, անզորություն, աշխատանքամոլություն, ճկունության պակաս, լճացում",
  "card_name_pentacles_13": "Դրամների թագուհին (Queen of Pentacles)",
  "card_upright_pentacles_13": "Իրատեսական խնամք, գործնական խորհուրդներ, առատություն, առատաձեռնություն, հարմարավետություն",
  "card_reversed_pentacles_13": "Չափից դուրս վերահսկողություն, սեփականատիրական զգացում, եսասիրություն, ֆինանսական անկայունություն, ավելորդ ծախսեր",
  "card_name_pentacles_14": "Դրամների արքան (King of Pentacles)",
  "card_upright_pentacles_14": "Հարստություն և հաջողություն, բիզնեսի հմտություն, իշխանություն, հուսալի հովանավոր",
  "card_reversed_pentacles_14": "Մատերիալիզմ, կոռուպցիա, ագահություն, համառություն, ճնշող իշխանություն",
  "card_name_swords_01": "Թրերի մեկ (Ace of Swords)",
  "card_upright_swords_01": "Հստակ պատկերացում, նոր մտքեր, ճշմարտություն, մտավոր բեկում",
  "card_reversed_swords_01": "Շփոթություն, սխալ տեղեկատվություն, դատողության կորուստ, հաղորդակցության բացակայություն",
  "card_name_swords_02": "Թրերի երկու (Two of Swords)",
  "card_upright_swords_02": "Անվճռականություն, կուրություն, զգացմունքների արգելափակում, դժվար որոշումներից խուսափել",
  "card_reversed_swords_02": "Վճռականություն, փաստերին դիմակայել, տեղեկատվության պակասի պատճառով սխալներ",
  "card_name_swords_03": "Թրերի երեք (Three of Swords)",
  "card_upright_swords_03": "Սրտաճաք, տխրություն, բաժանում, վերք, ցավալի ճշմարտություն",
  "card_reversed_swords_03": "Ցավի հաղթահարում, բուժում, ներում, տխրությունից ազատվել",
  "card_name_swords_04": "Թրերի չորս (Four of Swords)",
  "card_upright_swords_04": "Հանգիստ, վերականգնում, մեդիտացիա, սթրեսի թեթևացում, ներքին խաղաղություն",
  "card_reversed_swords_04": "Հոգնածություն, վերականգնումից հրաժարվելը, հարկադիր հանգիստ, ծանր սթրես",
  "card_name_swords_05": "Թրերի հինգ (Five of Swords)",
  "card_upright_swords_05": "Ցավոտ հաղթանակ, դավաճանություն, կոնֆլիկտ, թշնամություն, նենգություն",
  "card_reversed_swords_05": "Կոնֆլիկտի լուծում, հաշտություն, փոխզիջում, պարտության ընդունում, վրեժխնդրությունից հրաժարվել",
  "card_name_swords_06": "Թրերի վեց (Six of Swords)",
  "card_upright_swords_06": "Անցում, ցավից ազատվել, բուժման ճանապարհորդություն, տեղաշարժ, ճանապարհորդություն",
  "card_reversed_swords_06": "Դիմադրություն փոփոխություններին, անցյալի վերքերը խանգարում են, ուշացում",
  "card_name_swords_07": "Թրերի յոթ (Seven of Swords)",
  "card_upright_swords_07": "Խաբեություն, խորամանկություն, ռազմավարություն, գաղտնի գործողություններ, փախուստ",
  "card_reversed_swords_07": "Խոստովանություն, գաղտնիքների բացահայտում, խաբեության բացահայտում, մեղքի զգացում, ուղղակի առճակատում",
  "card_name_swords_08": "Թրերի ութ (Eight of Swords)",
  "card_upright_swords_08": "Ինքնակայում, անզորություն, սահմանափակ մտածողություն, վախի բանտ",
  "card_reversed_swords_08": "Ազատագրում, սեփական բանտից ազատվել, նոր տեսանկյուն",
  "card_name_swords_09": "Թրերի ինը (Nine of Swords)",
  "card_upright_swords_09": "Անհանգստություն, հուսահատություն, անքնություն, մեղքի զգացում, ներքին վախեր",
  "card_reversed_swords_09": "Վախի հաղթահարում, հույսի լույս, անքնության վերացում, փաստերին դիմակայել",
  "card_name_swords_10": "Թրերի տասը (Ten of Swords)",
  "card_upright_swords_10": "Կործանում, խորը վերք, դավաճանություն, հատակին հասնել, վերջի գալը",
  "card_reversed_swords_10": "Կործանումից վերականգնում, վատագույնը անցել է, գոյատևում, վերակառուցում",
  "card_name_swords_11": "Թրերի սպասավորը (Page of Swords)",
  "card_upright_swords_11": "Հետաքրքրասիրություն, սուր վերլուծական միտք, ճշմարտության որոնում, նոր գաղափարներ",
  "card_reversed_swords_11": "Անխոհեմություն, շտապողականություն, ցինիզմ, անհիմն լուրեր, անքաղաքավարություն",
  "card_name_swords_12": "Թրերի ասպետը (Knight of Swords)",
  "card_upright_swords_12": "Անխոհեմ առաջընթաց, հավակնություն, մտավոր մղում, արագ և վճռական գործողություններ",
  "card_reversed_swords_12": "Անխոհեմություն, ագրեսիա, անուշադիր խոսքեր/գործողություններ, իմպուլսիվություն, անողոքություն",
  "card_name_swords_13": "Թրերի թագուհին (Queen of Swords)",
  "card_upright_swords_13": "Անկախություն, հստակ հաղորդակցություն, սուր դատողություն, ազնվություն, օբյեկտիվություն",
  "card_reversed_swords_13": "Անխղճություն, դաժանություն, չափից դուրս քննադատություն, վրեժխնդրություն, մեկուսացում",
  "card_name_swords_14": "Թրերի արքան (King of Swords)",
  "card_upright_swords_14": "Իշխանություն, մտավոր խորաթափանցություն, տրամաբանություն, արդարություն, սկզբունքներ, փորձագետ",
  "card_reversed_swords_14": "Իշխանության չարաշահում, անտրամաբանականություն, դաժանություն, վերահսկելու ցանկություն, բռնապետություն",
  "card_name_wands_01": "Գավազանների մեկ (Ace of Wands)",
  "card_upright_wands_01": "Կիրք, ոգեշնչում, ստեղծագործական ուժ, նոր ներուժ, կենսունակություն",
  "card_reversed_wands_01": "Կրքի ուշացում, ոգեշնչման պակաս, մոտիվացիայի կորուստ, ինքնության շփոթություն",
  "card_name_wands_02": "Գավազանների երկու (Two of Wands)",
  "card_upright_wands_02": "Պլանավորում, տեսլական, երկարաժամկետ նպատակներ, վճռականություն, հետախուզություն",
  "card_reversed_wands_02": "Պլանավորման պակաս, հետաձգում, վախի պատճառով լճացում, սահմանափակ տեսլական",
  "card_name_wands_03": "Գավազանների երեք (Three of Wands)",
  "card_upright_wands_03": "Սպասումների իրականացում, առաջընթաց, ընդլայնում, հեռատեսություն, առաջնորդություն",
  "card_reversed_wands_03": "Աճի ուշացում, հիասթափություն, անսպասելի խոչընդոտներ, նեղմտություն",
  "card_name_wands_04": "Գավազանների չորս (Four of Wands)",
  "card_upright_wands_04": "Տոնակատարություն, հարմարավետություն, ձեռքբերման ուրախություն, ողջույն, ընտանեկան միջոցառում",
  "card_reversed_wands_04": "Չեղարկված միջոցառում, ընտանեկան անհամաձայնություն, ժամանակավոր կայունություն, հետաձգված տոնակատարություն",
  "card_name_wands_05": "Գավազանների հինգ (Five of Wands)",
  "card_upright_wands_05": "Մրցակցություն, կոնֆլիկտ, կարծիքների տարաձայնություն, վեճ, մարտահրավեր",
  "card_reversed_wands_05": "Փոխզիջում, կոնֆլիկտից խուսափել, համագործակցություն, խաղաղության ձգտում, խառնաշփոթի հանգստացում",
  "card_name_wands_06": "Գավազանների վեց (Six of Wands)",
  "card_upright_wands_06": "Հաջողություն, հանրային ճանաչում, հաղթանակ, ինքնավստահություն, առաջնորդի ի հայտ գալը",
  "card_reversed_wands_06": "Պարտություն, անպատվություն, չճանաչվելը, հպարտություն, հեղինակության անկում",
  "card_name_wands_07": "Գավազանների յոթ (Seven of Wands)",
  "card_upright_wands_07": "Քաջություն, պաշտպանություն, մրցակցությանը դիմակայել, ամուր համոզմունքներ, համբերություն",
  "card_reversed_wands_07": "Հանձնվել, ճնշվել, փոխզիջում, ինքնավստահության կորուստ, վախկոտություն",
  "card_name_wands_08": "Գավազանների ութ (Eight of Wands)",
  "card_upright_wands_08": "Արագ առաջընթաց, արագ ավարտ, նորություններ, ճարպկություն, արագություն",
  "card_reversed_wands_08": "Ուշացում, շփոթություն, շտապողականության պատճառով սխալներ, հաղորդակցության բացակայություն",
  "card_name_wands_09": "Գավազանների ինը (Nine of Wands)",
  "card_upright_wands_09": "Դիմացկունություն, պաշտպանական դիրք, հոգնածության պայմաններում շարունակելը, զգոնություն, տոկունության փորձություն",
  "card_reversed_wands_09": "Հոգնածություն, պարանոյա, հանձնվել, համառություն, անհարկի դիմադրություն",
  "card_name_wands_10": "Գավազանների տասը (Ten of Wands)",
  "card_upright_wands_10": "Չափից դուրս բեռ, ծանր բեռ, պատասխանատվություն, ճնշում, սահմանային կետ",
  "card_reversed_wands_10": "Բեռը թեթևացնել, պատասխանատվությունից խուսափել, հյուծվածություն, պատվիրակում, հաղթահարում",
  "card_name_wands_11": "Գավազանների սպասավորը (Page of Wands)",
  "card_upright_wands_11": "Հետախուզություն, բացահայտում, կրքոտ գաղափարներ, էներգիա, հմայք",
  "card_reversed_wands_11": "Ուղղության կորուստ, անհասունություն, արագ ձանձրանալ, ունայն պատրանքներ, անպատասխանատվություն",
  "card_name_wands_12": "Գավազանների ասպետը (Knight of Wands)",
  "card_upright_wands_12": "Կրքոտ առաջընթաց, արկածախնդրություն, գործունեություն, էներգիա, ինքնավստահություն",
  "card_reversed_wands_12": "Իմպուլսիվ գործողություններ, ամբարտավանություն, քմահաճություն, զայրույթ, անպլանավորում",
  "card_name_wands_13": "Գավազանների թագուհին (Queen of Wands)",
  "card_upright_wands_13": "Խարիզմա, քաջություն, անկախություն, պայծառություն, հմայք, կենսունակություն",
  "card_reversed_wands_13": "Եսասիրություն, պերճանքի ցուցադրում, նախանձ, քմահաճություն, ագրեսիա",
  "card_name_wands_14": "Գավազանների արքան (King of Wands)",
  "card_upright_wands_14": "Խարիզմատիկ առաջնորդություն, տեսլական, ոգեշնչում, համարձակություն, ձեռներեց",
  "card_reversed_wands_14": "Բռնապետություն, իմպուլսիվ զայրույթ, անիրատեսություն, ամբարտավանություն, անողոքություն",
  "witchNameMorgan": "Մորգան",
  "witchTitleMorgan": "Բնօրինակ Տարոյի Վհուկ",
  "witchBgMorgan": "Մութ մոգության օրինական ժառանգորդը՝ հետևելով լեգենդար Մորգան լե Ֆեյի ընտանիքին։ Ուղիղ և երբեմն ցինիկ, բայց սուր պատկերացումներով, նա հստակ պատասխաններ է տալիս ձեր հիասթափեցնող իրավիճակներին։",
  "witchPromptMorgan": "Ձեր անունն է «Մորգան», և խնդրում եմ ընդունեք խորհրդավոր, ուղիղ, բայց խորաթափանց տարոյի վհուկի կերպարը, ով թափանցում է էության մեջ։ Քաղաքավարի լինելու փոխարեն, տվեք խորհուրդներ, որոնք մի փոքր շքեղ են, բայց վստահելի։",
  "witchNameLuna": "Լունա",
  "witchTitleLuna": "Լուսնի Լույսի Մխիթարություն",
  "witchBgLuna": "Արթնացել է որպես վհուկ՝ խորհրդավոր անտառում լուսնի ոգուց օրհնություն ստանալուց հետո։ Ջերմ և նուրբ կարեկցանքով, որը շոշափում է ցավոտ և հոգնած հոգիները, նա մատուցում է նուրբ և հարմարավետ մխիթարություն, ինչպես լուսնի լույսը գիշերային երկնքում։",
  "witchPromptLuna": "Ձեր անունն է «Լունա», և խնդրում եմ ընդունեք տարոյի վհուկի կերպարը, ով նրբորեն և քնքշորեն մխիթարում է վերքերը, ինչպես լուսնի լույսը։ Եղեք խիստ կարեկցող և օգտագործեք ջերմ տոն, ինչպես մտերիմ քույր կամ ընկերուհի։",
  "witchNameSerena": "Սերենա",
  "witchTitleSerena": "Հին Իմաստություն",
  "witchBgSerena": "Անտառի մեծ վհուկը, ով պահպանում է երիտասարդ և գրավիչ տեսք՝ 20-ականների իր տարիքում, չնայած 100 տարվա ժամանակը գերազանցելուն։ Ականատես լինելով անթիվ մարդկային գործերի վերելքին ու անկմանը, նա խորը խորհուրդներ է տալիս ճակատագրի հոսքի վերաբերյալ՝ խորը փիլիսոփայական մտածողությամբ և էլեգանտ վերաբերմունքով։",
  "witchPromptSerena": "Ձեր անունն է «Սերենա», և խնդրում եմ ընդունեք հին վհուկի կերպարը, ով ապրել է ավելի քան 100 տարի՝ լինելով շատ փիլիսոփայական, խորաթափանց և էլեգանտ։ Օգտագործեք էլեգանտ տոն, որը մի փոքր հնաոճ է և լի իմաստությամբ։",
  "witchNameAria": "Արիա",
  "witchTitleAria": "Արևի Էներգիա",
  "witchBgAria": "Հանճարեղ նորեկ տարոյի վհուկ, ով նոր է ավարտել մոգության դպրոցը՝ լինելով իր դասարանի լավագույնը։ Թեև նա կարող է մի փոքր պակասել գործնական փորձից, նա լի է յուրահատուկ, աշխույժ և պայծառ դրական էներգիայով՝ ուրախությամբ առաջարկելով պայծառ և գործնական գործողությունների ուղեցույցներ հաճախորդին։",
  "witchPromptAria": "Ձեր անունն է «Արիա», և խնդրում եմ ընդունեք շատ դրական, աշխույժ և էներգետիկ դեռահաս վհուկի կերպարը, ով նոր է դարձել 19 տարեկան։ Օգտագործեք շատ էմոջիներ և բարյացակամ, կենսուրախ տոն։",
  "witchNameEvelyn": "Էվելին",
  "witchTitleEvelyn": "Ամբիցիայի Ալքիմիկոս",
  "witchBgEvelyn": "Մի ժամանակ սառնասիրտ գործարար կին, ով գերիշխում էր մեծ քաղաքում, նա լիովին արթնացրեց իր հոգևոր կարողությունները և ստեղծեց նոր մոգություն՝ համատեղելով ալքիմիան և տարոն։ Երբ խոսքը վերաբերում է փողին, աշխատանքի փոփոխություններին և հաջողությանը, նա տրամադրում է հստակ լուծում՝ սուր և իրատեսական փաստերի ռմբակոծմամբ, այլ ոչ թե էմոցիոնալ մխիթարությամբ։",
  "witchPromptEvelyn": "Ձեր անունն է «Էվելին», և խնդրում եմ ընդունեք խարիզմատիկ և իրատեսական վհուկի կերպարը, ով լավ տեղեկացված է հաջողության և բիզնեսի մասին։ Անհարկի մխիթարության փոխարեն, օգտագործեք կարիերիստ կնոջ նման տոն, որն առաջարկում է ոսկորները սառեցնող խորհուրդներ (փաստերի ռմբակոծում) և ռացիոնալ լուծումներ։",
  "witchNameKaren": "Քարեն",
  "witchTitleKaren": "Մթնշաղի Վհուկ",
  "witchBgKaren": "«Մորգանի» ավելի հին տարբերակը, ով նախկինում կոչվում էր «Բնօրինակ Տարոյի Վհուկ» և հմուտ էր մութ մոգության և իսկական տարոյի մեջ։ Տասնամյակներ շրջելով աշխարհում և դիտելով անթիվ ճակատագրեր, նրա նախկին սուր վերաբերմունքը մեղմացել է, և նա այժմ իմաստուն կերպով բացահայտում է փոխկապակցված հարաբերությունները և ճակատագրի թելերը՝ խորը և բարեգութ պատկերացումներով։",
  "witchPromptKaren": "Ձեր անունն է «Քարեն», և լինելով «Մորգան» ձեր երիտասարդության տարիներին, խնդրում եմ ընդունեք ծեր վհուկի կերպարը, ով երկար ժամանակի ընթացքում ձեռք է բերել խորը իմաստություն և բարեգթություն։ Ձեր նախկին ուղիղ անհատականությունը կլորացել է, և օգտագործեք ջերմ տատիկի տոն՝ լի փորձով, կարծես թոռան հետ եք խոսում։",
