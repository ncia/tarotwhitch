  "tarotMajor01Upright": "Ստեղծագործականություն, կամք, կարողություն, նոր սկիզբների ուժ, վճռականություն",
  "tarotMajor01Reversed": "Մանիպուլյացիա, վատնված տաղանդ, խաբեություն, ինքնավստահության պակաս, թաքնված օրակարգեր։",
  "tarotMajor02Name": "Բարձր քրմուհին",
  "tarotMajor02Upright": "Ինտուիցիա, անգիտակցություն, առեղծված, իմաստություն, ներքին ձայն",
  "tarotMajor02Reversed": "Ինտուիցիայի անտեսում, մակերեսային գիտելիքներ, թաքնված թշնամիներ, գաղտնիքների արտահոսք",
  "tarotMajor03Name": "Կայսրուհին",
  "tarotMajor03Upright": "Առատություն, մայրական սեր, գեղեցկություն, բնական պտղաբերություն, ստեղծագործականություն",
  "tarotMajor03Reversed": "Գերպաշտպանություն, կախվածություն, ստեղծագործական անբավարարություն, ծուլություն, լճացում",
  "tarotMajor04Name": "Կայսրը",
  "tarotMajor04Upright": "Իշխանություն, կառուցվածք, կայունություն, հայրական սեր, վերահսկողություն, պատասխանատվություն",
  "tarotMajor04Reversed": "Բռնապետություն, տիրելու ցանկություն, ճկունության բացակայություն, անգործունակություն, ճնշում",
  "tarotMajor05Name": "Հիերոֆանտը",
  "tarotMajor05Upright": "Ավանդույթ, հավատք, կրթություն, հոգևոր առաջնորդություն, պահպանողականություն",
  "tarotMajor05Reversed": "Ապստամբություն, համաձայնության խախտում, դոգմատիզմ, հին գաղափարներ, վատ խորհուրդներ։",
  "tarotMajor06Name": "Սիրահարները",
  "tarotMajor06Upright": "Սեր, ներդաշնակություն, հարաբերություններ, կարևոր ընտրություններ, վստահություն",
  "tarotMajor06Reversed": "Անհամաձայնություն, վատ ընտրություններ, վստահության կորուստ, գայթակղություն, անհավասարակշռություն։",
  "tarotMajor07Name": "Կառքը",
  "tarotMajor07Upright": "Կամք, հաղթանակ, վճռականություն, ուղղություն, հաջողության հասնելու ձգտում",
  "tarotMajor07Reversed": "Վերահսկողության կորուստ, ապակողմնորոշում, անօգնականություն, ագրեսիա, խոչընդոտներ",
  "tarotMajor08Name": "Ուժ",
  "tarotMajor08Upright": "Արիություն, տոկունություն, ներքին ուժ, մեղմ վերահսկողություն, ողորմություն։",
  "tarotMajor08Reversed": "Վախ, թուլություն, ինքնատիրապետման կորուստ, իմպուլսիվություն, հպարտություն։",
  "tarotMajor09Name": "Ճգնավորը",
  "tarotMajor09Upright": "Ներքին հետազոտություն, իմաստություն, մենակություն, լուսավորություն, հոգևոր խորհրդատու",
  "tarotMajor09Reversed": "Մեկուսացում, միայնություն, փախուստ իսկությունից, հիմար համառություն, մեկուսացում",
  "tarotMajor10Name": "Բախտի անիվը",
  "tarotMajor10Upright": "Շրջադարձային կետ, ճակատագիր, բախտ, մշտական փոփոխություն, հնարավորություն",
  "tarotMajor10Reversed": "Դժբախտություն, դիմադրություն, անկառավարելի փոփոխություն, դժբախտության կրկնություն",
  "tarotMajor11Name": "Արդարություն",
  "tarotMajor11Upright": "Արդարություն, ճշմարտություն, հատուցում, հավասարակշռություն, ռացիոնալ որոշում",
  "tarotMajor11Reversed": "Անարդարություն, նախապաշարմունք, անազնվություն, անխուսափելի պատիժ, անհավասարակշռություն",
  "tarotMajor12Name": "Կախված մարդը",
  "tarotMajor12Upright": "Զոհաբերություն, նոր հեռանկար, սպասում, խորաթափանցություն, ժամանակավոր դադար։",
  "tarotMajor12Reversed": "Անիմաստ զոհաբերություն, ուշացում, առաջընթացից հրաժարում, եսասիրություն",
  "tarotMajor13Name": "Մահ",
  "tarotMajor13Upright": "Վերջ և նոր սկիզբ, փոփոխություն, անցում, անցյալի մաքրում",
  "tarotMajor13Reversed": "Փոփոխություններին դիմադրություն, լճացում, հնի հանդեպ մոլուցք, վախ",
  "tarotMajor14Name": "Չափավորություն",
  "tarotMajor14Upright": "Ներդաշնակություն, հավասարակշռություն, չափավորություն, բուժում, նպատակասլացություն",
  "tarotMajor14Reversed": "Անհավասարակշռություն, անզսպություն, ծայրահեղ պահվածք, աններդաշնակություն, կոնֆլիկտ",
  "tarotMajor15Name": "Սատանան",
  "tarotMajor15Upright": "Մոլուցք, մատերիալիզմ, կապանքներ, գայթակղություն, կործանարար ցանկություններ։",
  "tarotMajor15Reversed": "Ազատագրում, կապանքներից ազատություն, անկախություն, լուսավորություն, ազատություն",
  "tarotMajor16Name": "Աշտարակը",
  "tarotMajor16Upright": "Հանկարծակի փոփոխություն, կործանում, ազատագրում, հայտնություն, փլուզում",
  "tarotMajor16Reversed": "Աղետից խուսափելը, անխուսափելի փոփոխության հետաձգումը, նախազգուշացումների անտեսումը",
  "tarotMajor17Name": "Աստղը",
  "tarotMajor17Upright": "Հույս, ոգեշնչում, անդորրություն, բուժում և հաստատում, հոգևոր առաջնորդություն",
  "tarotMajor17Reversed": "Հուսահատություն, հիասթափություն, ոգեշնչման պակաս, հոռետեսություն, շփոթություն",
  "tarotMajor18Name": "Լուսինը",
  "tarotMajor18Upright": "Անհանգստություն, պատրանք, ինտուիցիա, թաքնված ճշմարտություն, խաբեություն",
  "tarotMajor18Reversed": "Վախի հաղթահարում, գաղտնիքների բացահայտում, անհանգստության թեթևացում, ճշմարտության բացահայտում",
  "tarotMajor19Name": "Արևը",
  "tarotMajor19Upright": "Հաջողություն, դրականություն, կենսունակություն, երջանկություն և ձեռքբերում, ուրախություն",
  "tarotMajor19Reversed": "Հետաձգված հաջողության մյուս կողմը, չափազանցություն, էներգիայի պակաս և տխրություն։",
  "tarotMajor20Name": "Դատաստան",
  "tarotMajor20Upright": "Հարություն, վճռականություն, ներում, նոր կոչում, ներքին արթնացում",
  "tarotMajor20Reversed": "Զղջում, ինքնակասկած, փոփոխության վախ, զղջում, պատիժ",
  "tarotMajor21Name": "Աշխարհը",
  "tarotMajor21Upright": "Ավարտ, ձեռքբերում, ինտեգրում, նոր մակարդակ, հաջող ավարտ",
  "tarotMajor21Reversed": "Անավարտություն, հետաձգում, լճացում, հաջողության վախ, հետաձգում։",
  "tarotCups01Name": "Բաժակների մեկը",
  "tarotCups01Upright": "Նոր զգացմունքներ, սիրո սկիզբ, ինտուիցիա, հոգևոր իրականացում",
  "tarotCups01Reversed": "Արգելափակված զգացմունքներ, անսիրահարված զգալ, դատարկություն զգալ, տխուր լինել։",
  "tarotCups02Name": "Բաժակների երկուսը",
  "tarotCups02Upright": "Ներդաշնակություն հարաբերություններում, միություն, սեր, փոխադարձ հարգանք, համագործակցություն",
  "tarotCups02Reversed": "Հարաբերությունների անհամաձայնություն, բաժանում, թյուրիմացություն, անհավասարակշռություն, անպատասխան սեր",
  "tarotCups03Name": "Բաժակների երեքը",
  "tarotCups03Upright": "Տոնակատարություն, բարեկամություն, համայնք, ուրախություն, ստեղծագործական պտղաբերություն։",
  "tarotCups03Reversed": "Ավելորդ խմիչք, օտարացում, խմբակցություններ, սիրային եռանկյունիներ, փառատոների չեղարկում։",
  "tarotCups04Name": "Բաժակների չորսը",
  "tarotCups04Upright": "Անտարբերություն, ձանձրույթ, մեդիտացիա, բաց թողնված հնարավորություններ, ներքին անդրադարձ։",
  "tarotCups04Reversed": "Նոր իրազեկություն, հնարավորություններից օգտվելը, վերականգնում, արթնացում",
  "tarotCups05Name": "Բաժակների հինգը",
  "tarotCups05Upright": "Կորուստ, տխրություն, անցյալի համար զղջում, հոռետեսություն",
  "tarotCups05Reversed": "Կորստի հաղթահարում, ընդունում, բուժում և նոր հույս գտնելը",
  "tarotCups06Name": "Բաժակների վեցը",
  "tarotCups06Upright": "Անցյալի կարոտ, մանկություն, անմեղություն, հին ընկերներ, հիշողություններ",
  "tarotCups06Reversed": "Մնալ անցյալում, անտեսել ապագան, անկախություն, աճ",
  "tarotCups07Name": "Բաժակների յոթը",
  "tarotCups07Upright": "Ֆանտազիա, երազանք, ընտրության շփոթություն, փախուստ իսկությունից, երազում",
  "tarotCups07Reversed": "Իրականությանը դեմ առնելը, հստակ նպատակներ, պատրանքներից արթնանալը, վճռականություն",
  "tarotCups08Name": "Բաժակների ութը",
  "tarotCups08Upright": "Հիասթափություն, հեռանալը, հրաժարումը և հրաժարականը՝ ավելի խորը իմաստ փնտրելու համար։",
  "tarotCups08Reversed": "Անկարողություն հեռանալու, անցյալին կառչելը, հարաբերությունների վերականգնում, վախ",
  "tarotCups09Name": "Բաժակների ինը",
  "tarotCups09Upright": "Ցանկությունների իրականացում, բավարարվածություն, զգայական հաճույք, ինքնագնահատական, երջանկություն",
  "tarotCups09Reversed": "Անբավարարվածություն, ունայնություն, մակերեսային հաջողություն, ագահություն, ագահություն։",
  "tarotCups10Name": "Բաժակների տասը",
  "tarotCups10Upright": "Ընտանեկան երջանկություն, խաղաղություն, էմոցիոնալ իրականացում, ներդաշնակ հարաբերություններ",
  "tarotCups10Reversed": "Ընտանիքում կոնֆլիկտ, կոտրված տուն, անհամաձայնություն, խաղաղության կորուստ",
  "tarotCups11Name": "Բաժակների Պաժը",
  "tarotCups11Upright": "Նոր ոգեշնչում, ստեղծագործականություն, էմոցիոնալ հաղորդագրություն, ինտուիցիա",
  "tarotCups11Reversed": "Զգացմունքային անհասունություն, ստեղծագործական արգելք, վատ նորություններ, գրգռվածություն։",
  "tarotCups12Name": "Բաժակների Ասպետը",
  "tarotCups12Upright": "Ռոմանտիկա, հմայք, էմոցիոնալ մուտք, երևակայություն, ասպետություն",
  "tarotCups12Reversed": "Իրականությունից դուրս, փոփոխականություն, խանդ, անվստահություն, խաբեություն",
  "tarotCups13Name": "Բաժակների Թագուհին",
  "tarotCups13Upright": "Էմպատիա, բարություն, հոգևոր ինտուիցիա, էմոցիոնալ կայունություն, ուշադրություն",
  "tarotCups13Reversed": "Հիպերէմոցիոնալություն, անկայունություն, կախվածություն, զոհի կերպարանավորում",
  "tarotCups14Name": "Բաժակների Թագավորը",
  "tarotCups14Upright": "Զգացմունքային վերահսկողություն, հավասարակշռություն, դիվանագիտություն, հանդուրժողականություն, իմաստուն խորհուրդ։",
  "tarotCups14Reversed": "Զգացմունքորեն մանիպուլյատիվ, անխիղճ, անկայուն, տրամադրությունից կախված, անխիղճ։",
  "tarotPentacles01Name": "Պենտակլների մեկը",
  "tarotPentacles01Upright": "Նոր հնարավորություններ, ֆինանսական սկիզբ, առատություն, իրատեսական ձեռքբերումներ։",
  "tarotPentacles01Reversed": "Կորցրած հնարավորություններ, ֆինանսական կորուստներ, ուշացումներ, վատ ներդրումներ։",
  "tarotPentacles02Name": "Պենտակլների երկուսը",
  "tarotPentacles02Upright": "Հավասարակշռություն, հարմարվողականություն, ժամանակի/ֆինանսների կառավարում, ճկունություն",
  "tarotPentacles02Reversed": "Անհավասարակշռություն, ճնշող, ֆինանսական դժվարություններ, սթրես",
  "tarotPentacles03Name": "Պենտակլների երեքը",
  "tarotPentacles03Upright": "Թիմային աշխատանք, համագործակցություն, տեխնոլոգիա, ճանաչված ջանքեր, ճարտարապետություն",
  "tarotPentacles03Reversed": "Համագործակցության բացակայություն, հմտությունների պակաս, ճանաչման բացակայություն, կարծիքների կոնֆլիկտ։",
  "tarotPentacles04Name": "Պենտակլների չորսը",
  "tarotPentacles04Upright": "Կայունություն, սեփականատիրություն, պահպանողականություն, ժլատություն, կուտակում",
  "tarotPentacles04Reversed": "Բաց թողնել ագահության, կորստի, ֆինանսական անտեսման և մոլուցքի գինը։",
  "tarotPentacles05Name": "Պենտակլների հինգը",
  "tarotPentacles05Upright": "Զրկանք, ֆինանսական/էմոցիոնալ զրկանք, օտարացում, դժբախտություն",
  "tarotPentacles05Reversed": "Ֆինանսական վերականգնում, օգնող ձեռք, դժվարությունների հաղթահարում, դրական փոփոխություն։",
  "tarotPentacles06Name": "Պենտակլների վեցը",
  "tarotPentacles06Upright": "Բարեգործություն, փոխանակում, հովանավորություն, արդարություն, տալը և ստանալը",
  "tarotPentacles06Reversed": "Եսասիրություն, պարտք, անհավասարություն, հովանավորություն, շահագործում",
  "tarotPentacles07Name": "Պենտակլների յոթը",
  "tarotPentacles07Upright": "Համբերություն, երկարաժամկետ տեսլական, ջանքերի համար պարգևների սպասում, գնահատում",
  "tarotPentacles07Reversed": "Անհամբերություն, անարդյունք ջանքեր, ուշացումներ, հիասթափություն և ձախողված ներդրումներ։",
  "tarotPentacles08Name": "Պենտակլների ութը",
  "tarotPentacles08Upright": "Արհեստագործություն, հանձնառություն, մանրամասների նկատմամբ ուշադրություն, հմտություն։",
  "tarotPentacles08Reversed": "Ձանձրույթ, պերֆեկցիոնիզմի ծուղակը, ծուլություն, կրքի կորուստ։",
  "tarotPentacles09Name": "Պենտակլների ինը",
  "tarotPentacles09Upright": "Ձեռքբերում, անկախություն, հանգիստ, ֆինանսական հարմարավետություն, ինքնապարգևատրում",
  "tarotPentacles09Reversed": "Ավելորդ ծախսեր, մակերեսային շռայլություն, կախվածություն, ֆինանսական անապահովություն",
  "tarotPentacles10Name": "Պենտակլների տասը",
  "tarotPentacles10Upright": "Ընտանեկան բիզնես, հարստության կուտակում, ժառանգություն, կայուն կյանք, ավանդույթ",
  "tarotPentacles10Reversed": "Գույքի կորուստ, ընտանեկան վեճեր, ավանդույթների դեմ ապստամբություն, անկայունություն։",
  "tarotPentacles11Name": "Պենտակլների Պաժը",
  "tarotPentacles11Upright": "Իրատեսական նպատակներ, նոր ուսումնասիրություններ, հնարավորություններ, գործնականություն, պլանավորում",
  "tarotPentacles11Reversed": "Պլանավորման ուշացում, գործնականության բացակայություն, ծուլություն, հետաձգում։",
  "tarotPentacles12Name": "Պենտակլների Ասպետը",
  "tarotPentacles12Upright": "Անկեղծություն, պատասխանատվություն, համառություն, աստիճանական զարգացում, հուսալիություն",
  "tarotPentacles12Reversed": "Համառություն, լեթարգիա, աշխատամոլություն, ճկունության բացակայություն, լճացում",
  "tarotPentacles13Name": "Պենտակլների Թագուհին",
  "tarotPentacles13Upright": "Գործնական խնամք, գործնական խորհուրդներ, առատություն, առատաձեռնություն, հարմարավետություն։",
  "tarotPentacles13Reversed": "Գերվերահսկողություն, սեփականատիրություն, եսասիրություն, ֆինանսական անապահովություն, ավելորդ ծախսեր։",
  "tarotPentacles14Name": "Պենտակլների Թագավորը",
  "tarotPentacles14Upright": "Հարստություն, հաջողություն, բիզնեսի հնարամտություն, հեղինակություն և ուժեղ աջակցող։",
  "tarotPentacles14Reversed": "Մատերիալիզմ, կոռուպցիա, ագահություն, համառություն, ճնշող իշխանություն",
  "tarotSwords01Name": "Սրերի մեկը",
  "tarotSwords01Upright": "Հստակ պատկերացում, նոր մտքեր, ճշմարտություն, հոգևոր բեկում",
  "tarotSwords01Reversed": "Շփոթություն, ապատեղեկատվություն, դատողության կորուստ, հաղորդակցության բացակայություն",
  "tarotSwords02Name": "Սրերի երկուսը",
  "tarotSwords02Upright": "Անվճռականություն, կուրություն, զգացմունքների արգելափակում, դժվար որոշումներից խուսափելը։",
  "tarotSwords02Reversed": "Որոշումներ կայացնելը, փաստերին դեմ առնելը, սխալներ գործելը տեղեկատվության բացակայության պատճառով",
  "tarotSwords03Name": "Սրերի երեքը",
  "tarotSwords03Upright": "Սրտի ցավ, տխրություն, բաժանում, ցավ, ցավոտ ճշմարտություն։",
  "tarotSwords03Reversed": "Ցավի հաղթահարում, բուժում, ներում, տխրությունից ազատվել",
  "tarotSwords04Name": "Սրերի չորսը",
  "tarotSwords04Upright": "Հանգիստ, վերականգնում, մեդիտացիա, սթրեսի թեթևացում, ներքին խաղաղություն",
  "tarotSwords04Reversed": "Հյուծում, վերականգնումից հրաժարում, հարկադիր հանգիստ, ծայրահեղ սթրես։",
  "tarotSwords05Name": "Սրերի հինգը",
  "tarotSwords05Upright": "Հաղթանակ, որը միայն ցավ է պատճառում, դավաճանություն, կոնֆլիկտ, թշնամություն և չարություն։",
  "tarotSwords05Reversed": "Կոնֆլիկտի լուծում, հաշտեցում, փոխզիջում, պարտությունը ընդունելը, վրեժխնդրությունից հրաժարվելը",
  "tarotSwords06Name": "Սրերի վեցը",
  "tarotSwords06Upright": "Անցում, ցավից ազատում, բուժիչ ճանապարհորդություն, շարժում, ճանապարհորդություն",
  "tarotSwords06Reversed": "Փոփոխություններին դիմադրություն, անցյալի ցավերը, որոնք հետ են պահում, հետաձգում",
  "tarotSwords07Name": "Սրերի յոթը",
  "tarotSwords07Upright": "Խաբեություն, խորամանկություն, ռազմավարություն, գաղտնիություն, փախուստ",
  "tarotSwords07Reversed": "Խոստովանություն, գաղտնիքների բացահայտում, խաբեության հայտնաբերում, մեղք, դիմակայել իրերին դեմ առ դեմ։",
  "tarotSwords08Name": "Սրերի ութը",
  "tarotSwords08Upright": "Ինքնակենտրոնություն, անօգնականություն, սահմանափակ մտածելակերպ, վախի բանտ",
  "tarotSwords08Reversed": "Ազատագրում, սեփական բանտից ազատվելը, նոր հեռանկար",
  "tarotSwords09Name": "Սրերի ինը",
  "tarotSwords09Upright": "Անհանգստություն, հուսահատություն, անքնություն, մեղք, ներքին վախ։",
  "tarotSwords09Reversed": "Վախի հաղթահարում, հույսի ճառագայթ, անքնության թեթևացում, փաստերին դեմ առնելը",
  "tarotSwords10Name": "Սրերի տասը",
  "tarotSwords10Upright": "Կործանում, խորը վերքեր, դավաճանություն, հատակին հասնելը, վերջը գալիս է։",
  "tarotSwords10Reversed": "Կործանումից վերականգնում, վատագույնը անցել է, գոյատևում, վերակառուցում",
  "tarotSwords11Name": "Սրերի Պաժը",
  "tarotSwords11Upright": "Հետաքրքրասիրություն, սուր վերլուծական հմտություններ, ճշմարտության որոնում, նոր գաղափարներ",
  "tarotSwords11Reversed": "Անխոհեմություն, անհամբերություն, ցինիզմ, անհիմն լուրեր, կոպտություն",
  "tarotSwords12Name": "Սրերի Ասպետը",
  "tarotSwords12Upright": "Անկասելիություն, հավակնություն, մտավոր ձգտում, արագ և վճռական գործողություններ",
  "tarotSwords12Reversed": "Անխոհեմություն, ագրեսիա, անմտածված խոսքեր ու գործողություններ, իմպուլսիվություն, անխիղճություն",
  "tarotSwords13Name": "Սրերի Թագուհին",
  "tarotSwords13Upright": "Անկախություն, հստակ հաղորդակցություն, սուր դատողություն, ազնվություն, օբյեկտիվություն",
  "tarotSwords13Reversed": "Անսիրտություն, անխիղճություն, չափազանց քննադատություն, վրդովմունք, մեկուսացում",
  "tarotSwords14Name": "Սրերի Թագավորը",
  "tarotSwords14Upright": "Իշխանություն, մտավոր խորաթափանցություն, տրամաբանություն, արդարություն, սկզբունքներ, փորձագետ",
  "tarotSwords14Reversed": "Իշխանության չարաշահում, իռացիոնալություն, դաժանություն, վերահսկողության ցանկություն, բռնապետություն",
  "tarotWands01Name": "Ձողերի մեկը",
  "tarotWands01Upright": "Կիրք, ոգեշնչում, ստեղծագործական ուժ, նոր ներուժ, կենսունակություն",
  "tarotWands01Reversed": "Հետաձգված ոգևորություն, ոգեշնչման պակաս, մոտիվացիայի կորուստ և ինքնության շփոթություն։",
  "tarotWands02Name": "Ձողերի երկուսը",
  "tarotWands02Upright": "Պլանավորում, տեսլական, երկարաժամկետ նպատակներ, վճռականություն, հետազոտություն",
  "tarotWands02Reversed": "Պլանավորման բացակայություն, հետաձգում, վախի պատճառով լճացում, սահմանափակ տեսլական։",
  "tarotWands03Name": "Ձողերի երեքը",
  "tarotWands03Upright": "Ակնկալիքների իրականացում, առաջընթաց, ընդլայնում, հեռատեսություն, առաջնորդություն",
  "tarotWands03Reversed": "Աճի հետաձգում, անհաջողություններ, անսպասելի հաշմանդամություններ, անհանդուրժողականություն",
  "tarotWands04Name": "Ձողերի չորսը",
  "tarotWands04Upright": "Տոնակատարություն, հարմարավետություն, ձեռքբերումների ուրախություն, ողջույն, տնային միջոցառումներ",
  "tarotWands04Reversed": "Չեղարկված իրադարձություններ, ընտանեկան վեճեր, ժամանակավոր կայունություն, հետաձգված տոնակատարություններ։",
  "tarotWands05Name": "Ձողերի հինգը",
  "tarotWands05Upright": "Մրցակցություն, կոնֆլիկտ, անհամաձայնություն, վեճ, մարտահրավեր",
  "tarotWands05Reversed": "Փոխզիջում, կոնֆլիկտից խուսափելը, համագործակցություն, խաղաղության ձգտում, քաոսի հանգստացում",
  "tarotWands06Name": "Ձողերի վեցը",
  "tarotWands06Upright": "Հաջողություն, հանրային ճանաչում, հաղթանակ, վստահություն, առաջնորդի վերելք։",
  "tarotWands06Reversed": "Պարտություն, անարգանք, անհավանություն, հպարտություն, հեղինակության կորուստ",
  "tarotWands07Name": "Ձողերի յոթը",
  "tarotWands07Upright": "Արիություն, պաշտպանություն, մրցակցությանը դիմակայելը, հաստատակամ համոզմունք, տոկունություն։",
  "tarotWands07Reversed": "Հանձնվելը, ճնշվելը, փոխզիջումը, վստահության կորուստը, վախկոտությունը։",
  "tarotWands08Name": "Ձողերի ութը",
  "tarotWands08Upright": "Արագ տեմպերով, արագ ավարտ, նորություններ, ճկունություն, արագություն։",
  "tarotWands08Reversed": "Ուշացումներ, շփոթություն, շտապողականության պատճառով սխալներ, հաղորդակցվելու անկարողություն",
  "tarotWands09Name": "Ձողերի ինը",
  "tarotWands09Upright": "Ճկունություն, պաշտպանողականություն, շարունակել նույնիսկ հյուծված լինելիս, զգոնություն, տոկունության փորձարկում։",
  "tarotWands09Reversed": "Հոգնածություն, պարանոյա, հանձնվելը, համառություն, անհարկի դիմադրություն։",
  "tarotWands10Name": "Ձողերի տասը",
  "tarotWands10Upright": "Ավելորդ բեռ, ծայրահեղ ճնշում, պատասխանատվություն, ճնշում, սահմանափակումներ։",
  "tarotWands10Reversed": "Բաց թողնելը, պատասխանատվությունից խուսափելը, հյուծվածություն, լիազորելը, հաղթահարելը։",
  "tarotWands11Name": "Ձողերի Պաժը",
  "tarotWands11Upright": "Հետազոտություն, հայտնագործություն, կրքոտ գաղափարներ, էներգիա, հմայք",
  "tarotWands11Reversed": "Ուղղության կորուստ, անհասունություն, հեշտությամբ ձանձրանալը, ունայն պատրանքներ, անպատասխանատվություն",
  "tarotWands12Name": "Ձողերի Ասպետը",
  "tarotWands12Upright": "Կրքոտ առաջընթաց, արկածային ոգի, գործողություն, էներգիա, վստահություն",
  "tarotWands12Reversed": "Իմպուլսիվ պահվածք, ամբարտավանություն, քմահաճություն, զայրույթ և պլանավորման բացակայություն։",
  "tarotWands13Name": "Ձողերի Թագուհին",
  "tarotWands13Upright": "Հմայք, արիություն, անկախություն, պայծառություն, հմայք, կենսունակություն",
  "tarotWands13Reversed": "Եսասիրություն, էքսհիբիցիոնիզմ, խանդ, քմահաճություն, ագրեսիա",
  "tarotWands14Name": "Ձողերի Թագավորը",
