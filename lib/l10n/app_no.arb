  "card_reversed_wands_10": "Slippe byrden, unngå ansvar, utbrenthet, delegering, overvinne",
  "card_name_wands_11": "Stavenes Pasje (Page of Wands)",
  "card_upright_wands_11": "Utforskning, oppdagelse, lidenskapelige ideer, energi, sjarm",
  "card_reversed_wands_11": "Tap av retning, umodenhet, blir lett lei, fruktløse fantasier, uansvarlig",
  "card_name_wands_12": "Stavenes Ridder (Knight of Wands)",
  "card_upright_wands_12": "Lidenskapelig fremgang, eventyrlyst, handlekraft, energi, selvtillit",
  "card_reversed_wands_12": "Impulsive handlinger, arroganse, lunefullhet, sinne, mangel på planlegging",
