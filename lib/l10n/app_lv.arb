  "card_reversed_swords_12": "Pārgalvība, agresivitāte, neapdomīga valoda, impulsivitāte, nežēlība",
  "card_name_swords_13": "Zobenu Karaliene (Queen of Swords)",
  "card_upright_swords_13": "Neatkarība, skaidra komunikācija, ass spriedums, godīgums, objektivitāte",
  "card_reversed_swords_13": "Nežēlība, aukstasinība, pārmērīga kritika, aizvainojums, izolācija",
  "card_name_swords_14": "Zobenu Karalis (King of Swords)",
  "card_upright_swords_14": "Autoritāte, intelektuāla ieskats, loģika, godīgums, principi, eksperts",
  "card_reversed_swords_14": "Varas ļaunprātīga izmantošana, iracionalitāte, nežēlība, kontroles vēlme, diktatūra",
  "card_name_wands_01": "Zizļu Dūzis (Ace of Wands)",
  "card_upright_wands_01": "Kaislība, iedvesma, radošs spēks, jauns potenciāls, vitalitāte",
  "card_reversed_wands_01": "Kaislības aizkavēšanās, iedvesmas trūkums, motivācijas zudums, identitātes apjukums",
  "card_name_wands_02": "Divi Zizļi (Two of Wands)",
  "card_upright_wands_02": "Plānošana, vīzija, ilgtermiņa mērķi, apņēmība, izpēte",
  "card_reversed_wands_02": "Plānu trūkums, atlikšana, stagnācija baiļu dēļ, ierobežota vīzija",
  "card_name_wands_03": "Trīs Zizļi (Three of Wands)",
  "card_upright_wands_03": "Cerību piepildīšanās, progress, paplašināšanās, tālredzība, vadība",
  "card_reversed_wands_03": "Izaugsmes kavēšanās, vilšanās, negaidīti šķēršļi, šaurprātība",
  "card_name_wands_04": "Četri Zizļi (Four of Wands)",
  "card_upright_wands_04": "Svinības, komforts, sasniegumu prieks, viesmīlība, ģimenes pasākums",
  "card_reversed_wands_04": "Atcelts pasākums, ģimenes nesaskaņas, īslaicīga stabilitāte, aizkavētas svinības",
  "card_name_wands_05": "Pieci Zizļi (Five of Wands)",
  "card_upright_wands_05": "Konkurence, konflikts, viedokļu atšķirības, strīdi, izaicinājums",
  "card_reversed_wands_05": "Kompromiss, konflikta izvairīšanās, sadarbība, miera meklēšana, apjukuma nomierināšana",
  "card_name_wands_06": "Seši Zizļi (Six of Wands)",
  "card_upright_wands_06": "Panākumi, sabiedrības atzinība, uzvara, pašapziņa, līdera izcelšanās",
  "card_reversed_wands_06": "Sakāve, negods, neatzīšana, lepnums, reputācijas zudums",
  "card_name_wands_07": "Septiņi Zizļi (Seven of Wands)",
  "card_upright_wands_07": "Drosme, aizsardzība, stāšanās pretī konkurencei, stingra pārliecība, izturība",
  "card_reversed_wands_07": "Padošanās, pārslogojums, kompromiss, pašapziņas zudums, gļēvums",
  "card_name_wands_08": "Astoņi Zizļi (Eight of Wands)",
  "card_upright_wands_08": "Ātra gaita, ātra izbeigšanās, ziņas, veiklība, ātrums",
  "card_reversed_wands_08": "Kavēšanās, apjukums, kļūdas steigas dēļ, komunikācijas traucējumi",
  "card_name_wands_09": "Deviņi Zizļi (Nine of Wands)",
  "card_upright_wands_09": "Izturība, aizsardzības pozīcija, turpināt, neskatoties uz nogurumu, piesardzība, izturības pārbaudījums",
  "card_reversed_wands_09": "Nogurums, paranoja, padošanās, stūrgalvība, nevajadzīga pretestība",
  "card_name_wands_10": "Desmit Zizļi (Ten of Wands)",
  "card_upright_wands_10": "Pārmērīga nasta, ekstrēms slogs, atbildība, spiediens, robežpunkts",
  "card_reversed_wands_10": "Nastas atmešana, atbildības izvairīšanās, izdegšana, deleģēšana, pārvarēšana",
  "card_name_wands_11": "Zizļu Zēns (Page of Wands)",
  "card_upright_wands_11": "Izpēte, atklājumi, kaislīgas idejas, enerģija, pievilcība",
  "card_reversed_wands_11": "Virziena zaudēšana, nenobriedušība, ātra garlaicība, veltīgas ilūzijas, bezatbildība",
  "card_name_wands_12": "Zizļu Bruņinieks (Knight of Wands)",
  "card_upright_wands_12": "Kaislīga virzība uz priekšu, piedzīvojumu gars, rīcības spējas, enerģija, pašapziņa",
  "card_reversed_wands_12": "Impulsīva rīcība, augstprātība, kaprīzība, dusmas, neplānošana",
  "card_name_wands_13": "Zizļu Karaliene (Queen of Wands)",
  "card_upright_wands_13": "Harizma, drosme, neatkarība, gaišums, pievilcība, vitalitāte",
  "card_reversed_wands_13": "Egoisms, vēlme izrādīties, greizsirdība, kaprīzība, agresivitāte",
  "card_name_wands_14": "Zizļu Karalis (King of Wands)",
  "card_upright_wands_14": "Harizmātiska vadība, vīzija, iedvesma, drosme, uzņēmējs",
  "card_reversed_wands_14": "Diktatūra, impulsīvas dusmas, nereālisms, augstprātība, nežēlība",
  "witchNameMorgan": "Morgana",
  "witchTitleMorgan": "Oriģinālā Taro Ragana",
  "witchBgMorgan": "Leģendārās Morganas le Fejas ģimenes likumīgā tumšās maģijas pēctece. Tieša un reizēm ciniska, taču ar asu ieskatu viņa sniedz skaidras atbildes uz jūsu nomācošajām situācijām.",
  "witchPromptMorgan": "Jūsu vārds ir \"Morgana\", un, lūdzu, pieņemiet noslēpumainas, tiešas, taču ieskatīgas taro raganas tēlu, kura iekļūst būtībā. Tā vietā, lai būtu laipna, sniedziet padomus, kas ir nedaudz šiki, taču uzticami.",
  "witchNameLuna": "Luna",
  "witchTitleLuna": "Mēnessgaismas Mierinājums",
  "witchBgLuna": "Pamodusies kā ragana pēc mēness gara svētības saņemšanas noslēpumainā mežā. Ar siltu un smalku empātiju, kas aizskar ievainotas un nogurušas dvēseles, viņa sniedz maigu un mājīgu mierinājumu kā mēnessgaisma nakts debesīs.",
  "witchPromptLuna": "Jūsu vārds ir \"Luna\", un, lūdzu, pieņemiet taro raganas tēlu, kura maigi un sirsnīgi mierina brūces kā mēnessgaisma. Esiet ļoti empātiska un izmantojiet siltu toni kā tuva māsa vai draudzene.",
  "witchNameSerena": "Serēna",
  "witchTitleSerena": "Senā Gudrība",
  "witchBgSerena": "Lielā meža ragana, kura saglabā jaunu un pievilcīgu izskatu savos 20 gados, neskatoties uz to, ka ir pārsniegusi 100 gadu laiku. Redzējusi neskaitāmu cilvēku lietu uzplaukumu un norietu, viņa piedāvā dziļus padomus par likteņa plūsmu ar dziļu filozofisku domu un elegantu attieksmi.",
  "witchPromptSerena": "Jūsu vārds ir \"Serēna\", un, lūdzu, pieņemiet senas raganas tēlu, kura ir nodzīvojusi vairāk nekā 100 gadus, esot ļoti filozofiska, dziļa un eleganta. Izmantojiet elegantu toni, kas ir nedaudz vecmodīgs un pilns gudrības.",
  "witchNameAria": "Ārija",
  "witchTitleAria": "Saules Enerģija",
  "witchBgAria": "Ģeniāla iesācēja taro ragana, kura tikko absolvēja maģijas skolu ar izcilību. Lai gan viņai var trūkt nedaudz praktiskās pieredzes, viņa ir pilna ar unikālu, dzīvespriecīgu un gaišu pozitīvu enerģiju, jautri iesakot klientam gaišas un praktiskas rīcības vadlīnijas.",
  "witchPromptAria": "Jūsu vārds ir \"Ārija\", un, lūdzu, pieņemiet ļoti pozitīvas, dzīvespriecīgas un enerģiskas pusaudžu raganas tēlu, kura tikko sasniegusi 19 gadu vecumu. Izmantojiet daudz emocijzīmju un draudzīgu, dzīvīgu toni.",
  "witchNameEvelyn": "Evelīna",
  "witchTitleEvelyn": "Ambīciju Alķīmiķe",
  "witchBgEvelyn": "Reiz auksta uzņēmēja, kura dominēja lielpilsētā, viņa pilnībā pamodināja savas garīgās spējas un radīja jaunu maģiju, apvienojot alķīmiju un taro. Runājot par naudu, darba maiņām un panākumiem, viņa sniedz noteiktu risinājumu ar asu un reālistisku faktu bombardēšanu, nevis emocionālu mierinājumu.",
  "witchPromptEvelyn": "Jūsu vārds ir \"Evelīna\", un, lūdzu, pieņemiet harizmātiskas un reālistiskas raganas tēlu, kura labi pārzina panākumus un biznesu. Tā vietā, lai sniegtu nevajadzīgu mierinājumu, izmantojiet karjeras sievietes toni, kas piedāvā kaulus atvēsinošus padomus (faktu bombardēšanu) un racionālus risinājumus.",
  "witchNameKaren": "Kārena",
  "witchTitleKaren": "Krēslas Ragana",
  "witchBgKaren": "Vecākā 'Morganas' versija, kura agrāk tika dēvēta par 'Oriģinālo Taro Raganu' un bija prasmīga tumšajā maģijā un autentiskajā taro. Desmitgadēm ilgi klīstot pa pasauli un vērojot neskaitāmus likteņus, viņas agrāk asā attieksme ir mīkstinājusies, un tagad viņa gudri atšķetina savstarpēji saistītas attiecības un likteņa pavedienus ar dziļu un labvēlīgu ieskatu.",
  "witchPromptKaren": "Jūsu vārds ir \"Kārena\", un, būdama jaunībā 'Morgana', lūdzu, pieņemiet vecas raganas tēlu, kura ilgā laikā ir ieguvusi dziļu gudrību un labvēlību. Jūsu iepriekšējā tiešā personība ir noapaļojusies, un izmantojiet siltu vecmāmiņas toni, pilnu pieredzes, it kā izturoties pret mazbērnu.",
