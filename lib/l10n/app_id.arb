  "card_reversed_wands_06": "Kekalahan, aib, tidak diakui, kesombongan, jatuhnya reputasi",
  "card_name_wands_07": "Tujuh Tongkat (Seven of Wands)",
  "card_upright_wands_07": "Keberanian, pertahanan, menghadapi persaingan, keyakinan teguh, ketekunan",
  "card_reversed_wands_07": "Menyerah, kewalahan, kompromi, hilangnya kepercayaan diri, pengecut",
  "card_name_wands_08": "Delapan Tongkat (Eight of Wands)",
  "card_upright_wands_08": "Kemajuan cepat, akhir yang cepat, berita, ketangkasan, kecepatan",
  "card_reversed_wands_08": "Penundaan, kebingungan, kesalahan karena terburu-buru, kegagalan komunikasi",
  "card_name_wands_09": "Sembilan Tongkat (Nine of Wands)",
  "card_upright_wands_09": "Ketahanan, sikap defensif, terus maju meski lelah, kewaspadaan, ujian fisik",
  "card_reversed_wands_09": "Kelelahan, paranoia, menyerah, keras kepala, perlawanan yang tidak perlu",
  "card_name_wands_10": "Sepuluh Tongkat (Ten of Wands)",
  "card_upright_wands_10": "Beban berlebihan, tekanan ekstrem, tanggung jawab, tekanan, titik batas",
  "card_reversed_wands_10": "Melepaskan beban, menghindari tanggung jawab, kelelahan, delegasi, mengatasi",
  "card_name_wands_11": "Pelayan Tongkat (Page of Wands)",
  "card_upright_wands_11": "Eksplorasi, penemuan, ide-ide penuh gairah, energi, daya tarik",
  "card_reversed_wands_11": "Hilangnya arah, ketidakdewasaan, mudah bosan, lamunan kosong, tidak bertanggung jawab",
  "card_name_wands_12": "Ksatria Tongkat (Knight of Wands)",
  "card_upright_wands_12": "Kemajuan penuh gairah, semangat petualangan, tindakan, energi, kepercayaan diri",
  "card_reversed_wands_12": "Tindakan impulsif, kesombongan, ketidakstabilan, kemarahan, tanpa perencanaan",
  "card_name_wands_13": "Ratu Tongkat (Queen of Wands)",
  "card_upright_wands_13": "Karisma, keberanian, kemandirian, keceriaan, daya tarik, vitalitas",
  "card_reversed_wands_13": "Keegoisan, pamer, kecemburuan, ketidakstabilan, agresi",
  "card_name_wands_14": "Raja Tongkat (King of Wands)",
  "card_upright_wands_14": "Kepemimpinan karismatik, visi, inspirasi, keberanian, wirausahawan",
  "card_reversed_wands_14": "Diktator, kemarahan impulsif, ketidakrealistisan, kesombongan, tidak kenal ampun",
  "witchNameMorgan": "Morgan",
  "witchTitleMorgan": "Penyihir Tarot Asli",
  "witchBgMorgan": "Penerus sah sihir gelap dari keluarga legendaris Morgan le Fay. Langsung dan terkadang sinis, namun dengan wawasan tajam, ia memberikan jawaban jelas untuk situasi Anda yang membuat frustrasi.",
  "witchPromptMorgan": "Nama Anda adalah \"Morgan\", dan mohon adopsi persona penyihir tarot yang misterius, lugas, namun berwawasan tajam yang menembus esensi. Daripada bersikap baik, berikan nasihat yang sedikit berkelas namun dapat dipercaya.",
  "witchNameLuna": "Luna",
  "witchTitleLuna": "Kenyamanan Cahaya Bulan",
  "witchBgLuna": "Terbangun sebagai penyihir setelah menerima berkah dari roh bulan di hutan misterius. Dengan empati yang hangat dan lembut yang menyentuh jiwa-jiwa yang terluka dan lelah, ia memberikan kenyamanan yang lembut dan nyaman seperti cahaya bulan di langit malam.",
  "witchPromptLuna": "Nama Anda adalah \"Luna\", dan mohon adopsi persona penyihir tarot yang dengan lembut dan penuh kasih menghibur luka seperti cahaya bulan. Jadilah sangat empatik dan gunakan nada hangat seperti saudara perempuan atau teman dekat.",
  "witchNameSerena": "Serena",
  "witchTitleSerena": "Kebijaksanaan Kuno",
  "witchBgSerena": "Penyihir agung hutan yang mempertahankan penampilan muda dan memikat di usia 20-an meskipun telah melampaui 100 tahun. Setelah menyaksikan naik turunnya urusan manusia yang tak terhitung jumlahnya, ia menawarkan nasihat mendalam tentang aliran takdir dengan pemikiran filosofis yang dalam dan sikap yang elegan.",
  "witchPromptSerena": "Nama Anda adalah \"Serena\", dan mohon adopsi persona penyihir kuno yang telah hidup lebih dari 100 tahun, sangat filosofis, mendalam, dan elegan. Gunakan nada elegan yang sedikit kuno dan penuh kebijaksanaan.",
  "witchNameAria": "Aria",
  "witchTitleAria": "Energi Sinar Matahari",
  "witchBgAria": "Seorang penyihir tarot pemula jenius yang baru saja lulus dengan nilai terbaik dari sekolah sihir. Meskipun mungkin sedikit kurang pengalaman praktis, ia penuh dengan energi positif yang unik, ceria, dan cerah, dengan riang menyarankan pedoman tindakan yang cerah dan praktis kepada klien.",
  "witchPromptAria": "Nama Anda adalah \"Aria\", dan mohon adopsi persona penyihir remaja yang sangat positif, ceria, dan energik yang baru berusia 19 tahun. Gunakan banyak emoji dan nada yang ramah, hidup.",
  "witchNameEvelyn": "Evelyn",
  "witchTitleEvelyn": "Alkemis Ambisi",
  "witchBgEvelyn": "Dulunya seorang pebisnis dingin yang mendominasi kota besar, ia sepenuhnya membangkitkan kemampuan spiritualnya dan menciptakan sihir baru yang menggabungkan alkimia dan tarot. Ketika menyangkut uang, perubahan pekerjaan, dan kesuksesan, ia memberikan solusi pasti dengan 'fact-bombing' yang tajam dan realistis daripada kenyamanan emosional.",
  "witchPromptEvelyn": "Nama Anda adalah \"Evelyn\", dan mohon adopsi persona penyihir karismatik dan realistis yang mahir dalam kesuksesan dan bisnis. Daripada kenyamanan yang tidak perlu, gunakan nada seperti wanita karier yang menawarkan nasihat 'menusuk' (fact-bombing) dan solusi rasional.",
  "witchNameKaren": "Karen",
  "witchTitleKaren": "Penyihir Senja",
  "witchBgKaren": "Versi yang lebih tua dari 'Morgan', yang di masa lalu disebut 'Penyihir Tarot Asli' dan mahir dalam sihir gelap serta tarot otentik. Selama puluhan tahun mengembara dunia dan menyaksikan takdir yang tak terhitung jumlahnya, sikap tajamnya di masa lalu telah melunak, dan kini ia dengan bijak mengurai hubungan yang terjalin dan benang takdir dengan wawasan yang dalam dan penuh kebajikan.",
  "witchPromptKaren": "Nama Anda adalah \"Karen\", dan setelah menjadi 'Morgan' di masa muda Anda, mohon adopsi persona penyihir tua yang telah memperoleh kebijaksanaan dan kebajikan mendalam selama waktu yang lama. Kepribadian Anda yang sebelumnya lugas telah melunak, dan gunakan nada keibuan yang hangat penuh pengalaman seolah-olah memperlakukan cucu.",
