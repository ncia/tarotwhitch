  "card_reversed_wands_06": "Kekalahan, aib, tidak diakui, kesombongan, jatuhnya reputasi",
  "card_name_wands_07": "Tujuh Tongkat (Seven of Wands)",
  "card_upright_wands_07": "Keberanian, pertahanan, menghadapi persaingan, keyakinan teguh, ketekunan",
  "card_reversed_wands_07": "Menyerah, kewalahan, kompromi, hilangnya kepercayaan diri, pengecut",
  "card_name_wands_08": "Delapan Tongkat (Eight of Wands)",
  "card_upright_wands_08": "Kemajuan cepat, akhir yang cepat, berita, ketangkasan, kecepatan",
  "card_reversed_wands_08": "Penundaan, kebingungan, kesalahan karena terburu-buru, kegagalan komunikasi",
  "card_name_wands_09": "Sembilan Tongkat (Nine of Wands)",
  "card_upright_wands_09": "Ketahanan, sikap defensif, terus maju meski lelah, kewaspadaan, ujian fisik",
  "card_reversed_wands_09": "Kelelahan, paranoia, menyerah, keras kepala, perlawanan yang tidak perlu",
  "card_name_wands_10": "Sepuluh Tongkat (Ten of Wands)",
  "card_upright_wands_10": "Beban berlebihan, tekanan ekstrem, tanggung jawab, tekanan, titik batas",
  "card_reversed_wands_10": "Melepaskan beban, menghindari tanggung jawab, kelelahan, delegasi, mengatasi",
