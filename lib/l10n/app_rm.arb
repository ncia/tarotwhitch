  "tarotMajor00Name": "0. Il Nar (The Fool)",
  "tarotMajor00Upright": "Nov cumenzament, aventura, pussaivladads infinitas, libertad, purezza",
  "tarotMajor00Reversed": "Temerariadad, stupiditad, negligientscha, riscar memia bler, irrealtad",
  "tarotMajor01Name": "I. Il Mag (The Magician)",
  "tarotMajor01Upright": "Creativitad, voluntad, abilitad, forza d'in nov cumenzament, decisivdad",
  "tarotMajor01Reversed": "Manipulaziun, sperdita da talent, engianament, mancanza da fidanza, intenziuns zuppadas",
  "tarotMajor02Name": "II. La Sacerdotessa Gronda (The High Priestess)",
  "tarotMajor02Upright": "Intuitiziun, inconscient, misteri, savida, vusch interna",
  "tarotMajor02Reversed": "Ignorar l'intuitiziun, savida superficiala, inimis zuppads, revelaziun da secrets",
  "tarotMajor03Name": "III. L'Imperatura (The Empress)",
  "tarotMajor03Upright": "Abundanza, amur materna, bellezza, fritgs da la natira, creativitad",
  "tarotMajor03Reversed": "Surprotecziun, dependenza, mancanza creativa, pigrizia, stagnaziun",
  "tarotMajor04Name": "IV. L'Imperatur (The Emperor)",
  "tarotMajor04Upright": "Autoritad, structura, stabilitad, amur paterna, controlla, responsabladad",
  "tarotMajor04Reversed": "Dictatura, brama da dominar, mancanza da flexibilitad, inabilitad, suppressiun",
  "tarotMajor05Name": "V. Il Papa (The Hierophant)",
  "tarotMajor05Upright": "Tradiziun, cretta, educaziun, guida spirituala, conservatissem",
  "tarotMajor05Reversed": "Rebelliun, rumper cun las convenziuns, attituda dogmatica, veglias ideas, mal cussegl",
  "tarotMajor06Name": "VI. Ils Amants (The Lovers)",
  "tarotMajor06Upright": "Amur, armonia, relaziuns, impurtanta tscherna, fidanza",
  "tarotMajor06Reversed": "Discordia, tscherna fallada, perdita da fidanza, tentaziun, sbilantscha",
  "tarotMajor07Name": "VII. Il Chariot (The Chariot)",
  "tarotMajor07Upright": "Voluntad, victoria, decisivdad, direcziun, forza per il success",
  "tarotMajor07Reversed": "Perdita da controlla, perdita da direcziun, impotenza, agressiun, obstachels",
  "tarotMajor08Name": "VIII. Forza (Strength)",
  "tarotMajor08Upright": "Curaschi, pazienza, forza interna, controlla dultschanta, cumplainta",
  "tarotMajor08Reversed": "Tema, flaivlezza, perdita d'autocontrolla, impuls, superbia",
  "tarotMajor09Name": "IX. L'Eremit (The Hermit)",
  "tarotMajor09Upright": "Exploraziun interna, savida, solitariadad, illuminaziun, cusseglier spiritual",
  "tarotMajor09Reversed": "Isolaziun, solitariadad, fugia da la realitad, testardad stupida, eremitadi",
  "tarotMajor10Name": "X. La roda da la fortuna (Wheel of Fortune)",
  "tarotMajor10Upright": "Punct da midada, destin, fortuna, midada cuntinuanta, chaschun",
  "tarotMajor10Reversed": "Sfortuna, resistenza, midada nuncontrollabla, repetiziun da malaveglia",
  "tarotMajor11Name": "XI. Giustia (Justice)",
  "tarotMajor11Upright": "Fairness, vardad, karma, bilantscha, decisiun raziunala",
  "tarotMajor11Reversed": "Ingiustia, pregiudizi, disonestà, chastì inevitabel, sbilantscha",
  "tarotMajor12Name": "XII. L'Um pendì (The Hanged Man)",
  "tarotMajor12Upright": "Sacrifizi, nova perspectiva, spetga, perspicacitad, pausa temporara",
  "tarotMajor12Reversed": "Sacrifizi senza senn, retard, refusa da progress, egoissem",
  "tarotMajor13Name": "XIII. Mort (Death)",
  "tarotMajor13Upright": "Fin e nov cumenzament, midada, perioda da transiziun, liquidaziun dal passà",
  "tarotMajor13Reversed": "Resistenza cunter midada, stagnaziun, s'agrippar al vegl, tema",
  "tarotMajor14Name": "XIV. Temperanza (Temperance)",
  "tarotMajor14Upright": "Armonia, bilantscha, moderaziun, guariziun, senn da scop",
  "tarotMajor14Reversed": "Sbilantscha, intemperanza, acziuns extremas, disarmonia, conflict",
  "tarotMajor15Name": "XV. Il Diavel (The Devil)",
  "tarotMajor15Upright": "Obsessiun, materialissem, liom, tentaziun, desideri destructiv",
  "tarotMajor15Reversed": "Liberaziun, s'allontanar da lioms, independenza, illuminaziun, libertad",
  "tarotMajor16Name": "XVI. La Tur (The Tower)",
  "tarotMajor16Upright": "Midada subitana, destrucziun, liberaziun, revelaziun, collaps",
  "tarotMajor16Reversed": "Evitar catastrofas, retardar midada inevitabla, ignorar avertiments",
  "tarotMajor17Name": "XVII. La Staila (The Star)",
  "tarotMajor17Upright": "Speranza, inspiraziun, pasch, guariziun e positivadad, guida spirituala",
  "tarotMajor17Reversed": "Desperaziun, dischillusiun, mancanza d'inspiraziun, pessimissem, confusiun",
  "tarotMajor18Name": "XVIII. La Glina (The Moon)",
  "tarotMajor18Upright": "Inquietud, illusiun, intuitiziun, vardad zuppada, engianament",
  "tarotMajor18Reversed": "Survegnir la tema, scuvrir secrets, schliar inquietud, chattar la vardad",
  "tarotMajor19Name": "XIX. Il Sulegl (The Sun)",
  "tarotMajor19Upright": "Success, positivadad, vitalitad, fortuna e realisaziun, legria",
  "tarotMajor19Reversed": "Success retardà, exageraziun, vitalitad reducida, l'autra vart da la tristezza",
  "tarotMajor20Name": "XX. Il Giudizi (The Judgement)",
  "tarotMajor20Upright": "Resurrecziun, decisiun, perdun, nova vocaziun, svegl intern",
  "tarotMajor20Reversed": "Regret, dubi da sasez, tema da midada, nostalgia, chastì",
  "tarotMajor21Name": "XXI. Il Mund (The World)",
  "tarotMajor21Upright": "Cumplettaziun, realisaziun, integraziun, nova dimensiun, finiziun cun success",
  "tarotMajor21Reversed": "Nunfinì, retard, stagnaziun, tema dal success, retard",
  "tarotCups01Name": "As da Cuppas (Ace of Cups)",
  "tarotCups01Upright": "Novas emoziuns, cumenzament d'amur, intuitiziun, cumplettadad spirituala",
  "tarotCups01Reversed": "Bloccada d'emoziuns, betg amà, videt, tristezza",
  "tarotCups02Name": "2 da Cuppas (Two of Cups)",
