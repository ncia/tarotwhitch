  "card_upright_wands_13": "Carisma, coragem, independência, brilho, charme, vitalidade",
  "card_reversed_wands_13": "Egoísmo, exibicionismo, ciúme, inconstância, agressividade",
  "card_name_wands_14": "Rei de Paus (King of Wands)",
  "card_upright_wands_14": "Liderança carismática, visão, inspiração, ousadia, empreendedor",
