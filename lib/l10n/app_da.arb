  "card_reversed_wands_09": "Træthed, paranoia, opgivelse, stædighed, unødvendig modstand",
  "card_name_wands_10": "Ti Stave (Ten of Wands)",
  "card_upright_wands_10": "Overdreven byrde, ekstrem belastning, ansvar, pres, bristepunkt",
  "card_reversed_wands_10": "At lægge byrder fra sig, undgå ansvar, udbrændthed, delegation, overvindelse",
  "card_name_wands_11": "Stavenes Knægt (Page of Wands)",
  "card_upright_wands_11": "Udforskning, opdagelse, passionerede ideer, energi, charme",
  "card_reversed_wands_11": "Retningsløshed, umodenhed, keder sig let, tomme illusioner, uansvarlighed",
  "card_name_wands_12": "Stavenes Ridder (Knight of Wands)",
  "card_upright_wands_12": "Lidenskabelig fremmarch, eventyrlyst, handlekraft, energi, selvtillid",
  "card_reversed_wands_12": "Impulsiv handling, arrogance, lunefuldhed, vrede, mangel på planlægning",
  "card_name_wands_13": "Stavenes Dronning (Queen of Wands)",
  "card_upright_wands_13": "Karisma, mod, uafhængighed, lyshed, charme, vitalitet",
  "card_reversed_wands_13": "Selviskhed, praleri, jalousi, lunefuldhed, aggression",
  "card_name_wands_14": "Stavenes Konge (King of Wands)",
  "card_upright_wands_14": "Karismatisk lederskab, vision, inspiration, dristighed, iværksætter",
